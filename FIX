    });
  });
  mo.appendChild(mk("div","",`<div style="font-weight:800;font-size:13px;color:#5a7a99;text-transform:uppercase;margin:16px 0 10px">All Evaluations</div>`));
  evals.sort((a,b)=>new Date(b.eval_date)-new Date(a.eval_date)).forEach(e=>{
    const row=div("row"); row.style.cssText="background:#f5faff;border:1.5px solid #b8d9f0;border-radius:10px;padding:12px 14px;margin-bottom:8px";
    append(row,mk("span","",`<span style="font-weight:700">${fmt(e.eval_date)}</span>`),el("span",{class:`badge ${e.status}`},e.status),div("sp"),mk("span","",`<span style="font-weight:800;color:#2196f3;font-size:16px">${avg(e.scores)}/5</span>`));
    mo.appendChild(row);
  });
  return mo;
}

function modalEvalDetail(ev,cs){
  const mo=baseModal("Evaluation Details",true);
  const m=S.mitras.find(x=>x.id===ev.mitra_id);
  const hdr=div("row"); hdr.style.cssText="background:#d6ecfb;border-radius:12px;padding:14px;margin-bottom:18px";
  append(hdr,av(m?.name||"?",44),(()=>{const d=div(""); d.innerHTML=`<div style="font-weight:800;font-size:15px">${m?.name||"Unknown"}</div><div style="font-size:12px;color:#5a7a99">${fmt(ev.eval_date)}</div>`; return d;})(),div("sp"),el("span",{class:`badge ${ev.status}`},ev.status));
  mo.appendChild(hdr);
  cs.forEach(cat=>{
    mo.appendChild(mk("div","",`<div style="font-family:Poppins,sans-serif;font-weight:800;font-size:13px;color:#1565c0;margin-bottom:8px;margin-top:14px;text-transform:uppercase">${cat.name}</div>`));
    cat.subs.forEach(sub=>{
      const s=ev.scores[sub.id]||0;
      const sr=div("srow"); sr.appendChild(mk("span","slbl",sub.name));
      const dots=div(""); dots.style.display="flex"; dots.style.gap="6px";
      [1,2,3,4,5].forEach(v=>{ const d=div(""); d.style.cssText=`width:30px;height:30px;border-radius:7px;display:flex;align-items:center;justify-content:center;background:${v===s?(v>=4?"#00c853":v>=3?"#ff9800":"#f44336"):"#d6ecfb"};color:${v===s?"#fff":"#5a7a99"};font-weight:800;font-size:13px;border:1.5px solid ${v===s?"transparent":"#b8d9f0"}`; d.textContent=v; dots.appendChild(d); });
      sr.appendChild(dots); mo.appendChild(sr);
    });
  });
  if(ev.notes) mo.appendChild(mk("div","",`<div style="background:#f5faff;border:1.5px solid #b8d9f0;border-radius:10px;padding:14px;font-size:13px;color:#5a7a99;margin-top:14px">📝 ${ev.notes}</div>`));
  return mo;
}

function modalEvalWizard(data,cs){
  const mo=baseModal(data?.id?"Edit Evaluation":"New Evaluation",true);
  const allSubs=cs.flatMap(c=>c.subs);
  const initSc={}; allSubs.forEach(s=>initSc[s.id]=3);
  const form={mitraId:data?.mitraId||data?.mitra_id||"",date:data?.eval_date||new Date().toISOString().split("T")[0],notes:data?.notes||"",id:data?.id||null,scores:{...initSc,...(data?.scores||{})}};
  let step=1; const stepLabels=["Select Mitra","Score Competencies","Review & Submit"];
  const body=div(""); mo.appendChild(body);

  function redraw(){
    body.innerHTML="";
    // Wizard steps
    const sw=div("wiz-steps");
    stepLabels.forEach((label,i)=>{ const n=i+1,done=step>n,active=step===n; const si=div("wiz-step"); si.innerHTML=`<div class="wiz-c ${done?"done":active?"active":"pend"}">${done?"✓":n}</div><span class="wiz-l${active?" active":""}">${label}</span>${i<stepLabels.length-1?`<div class="wiz-line${done?" done":""}"></div>`:""}`; sw.appendChild(si); }); body.appendChild(sw);

    if(step===1){
      const f1=div("frow"); f1.appendChild(mk("label","fl2","Select Mitra *"));
      const sel=el("select",{class:"fi-s"}); sel.innerHTML='<option value="">Choose a mitra…</option>';
      S.mitras.forEach(m=>{ const o=el("option",{value:m.id},m.name+(m.employee_id?" ("+m.employee_id+")":"")); if(m.id===form.mitraId)o.selected=true; sel.appendChild(o); });
      sel.onchange=()=>form.mitraId=sel.value; f1.appendChild(sel); body.appendChild(f1);
      const f2=div("frow"); f2.appendChild(mk("label","fl2","Evaluation Date"));
      const di=el("input",{class:"fi-s",type:"date",value:form.date}); di.onchange=()=>form.date=di.value; f2.appendChild(di); body.appendChild(f2);
      const row=div("row"); row.style.marginTop="20px"; row.appendChild(div("sp"));
      row.appendChild(btn("btn-p","Next: Score Competencies →",()=>{ if(!form.mitraId) return; step=2; rewindow.onerror=function(msg,src,line){
  document.getElementById("root").innerHTML="<div style='padding:40px;font-family:sans-serif;background:#fff;margin:40px;border-radius:12px;border:2px solid red'><h2 style='color:red'>JS Error</h2><p>"+msg+"</p><p>Line: "+line+"</p></div>";
};
try{ draw(); }catch(e){
  document.getElementById("root").innerHTML="<div style='padding:40px;font-family:sans-serif;background:#fff;margin:40px;border-radius:12px;border:2px solid red'><h2 style='color:red'>Error</h2><p>"+e.message+"</p><pre style='font-size:11px;margin-top:8px'>"+e.stack+"</pre></div>";
} }));
      body.appendChild(row);
    } else if(step===2){
      const info=div("info-bar"); info.textContent="💡 Score 1 (poor) to 5 (excellent). Tap a number."; body.appendChild(info);
      cs.forEach(cat=>{
        const ch=div(""); ch.style.marginBottom="20px";
        ch.appendChild(mk("div","",`<div style="font-family:Poppins,sans-serif;font-weight:800;font-size:14px;color:#1565c0;margin-bottom:10px;padding:8px 12px;background:#d6ecfb;border-radius:8px">📁 ${cat.name}</div>`));
        cat.subs.forEach(sub=>{
          const sr=div("srow"); sr.appendChild(mk("span","slbl",sub.name));
          const sbts=div("sbts");
          [1,2,3,4,5].forEach(v=>{ const sb=btn(`sbt s${v}${form.scores[sub.id]===v?" act":""}`,String(v),()=>{ form.scores[sub.id]=v; rewindow.onerror=function(msg,src,line){
  document.getElementById("root").innerHTML="<div style='padding:40px;font-family:sans-serif;background:#fff;margin:40px;border-radius:12px;border:2px solid red'><h2 style='color:red'>JS Error</h2><p>"+msg+"</p><p>Line: "+line+"</p></div>";
};
try{ draw(); }catch(e){
  document.getElementById("root").innerHTML="<div style='padding:40px;font-family:sans-serif;background:#fff;margin:40px;border-radius:12px;border:2px solid red'><h2 style='color:red'>Error</h2><p>"+e.message+"</p><pre style='font-size:11px;margin-top:8px'>"+e.stack+"</pre></div>";
} }); sbts.appendChild(sb); });
          sr.appendChild(sbts); ch.appendChild(sr);
        }); body.appendChild(ch);
      });
      const row=div("row"); row.style.marginTop="16px";
      row.appendChild(btn("btn-g","← Back",()=>{ step=1; rewindow.onerror=function(msg,src,line){
  document.getElementById("root").innerHTML="<div style='padding:40px;font-family:sans-serif;background:#fff;margin:40px;border-radius:12px;border:2px solid red'><h2 style='color:red'>JS Error</h2><p>"+msg+"</p><p>Line: "+line+"</p></div>";
};
try{ draw(); }catch(e){
  document.getElementById("root").innerHTML="<div style='padding:40px;font-family:sans-serif;background:#fff;margin:40px;border-radius:12px;border:2px solid red'><h2 style='color:red'>Error</h2><p>"+e.message+"</p><pre style='font-size:11px;margin-top:8px'>"+e.stack+"</pre></div>";
} })); row.appendChild(div("sp"));
      row.appendChild(mk("span","",`<span style="font-size:13px;font-weight:700;color:#5a7a99">Overall: <span style="color:#2196f3;font-size:16px">${avg(form.scores)}</span>/5</span>`));
      row.appendChild(btn("btn-p","Next: Review →",()=>{ step=3; rewindow.onerror=function(msg,src,line){
  document.getElementById("root").innerHTML="<div style='padding:40px;font-family:sans-serif;background:#fff;margin:40px;border-radius:12px;border:2px solid red'><h2 style='color:red'>JS Error</h2><p>"+msg+"</p><p>Line: "+line+"</p></div>";
};
try{ draw(); }catch(e){
  document.getElementById("root").innerHTML="<div style='padding:40px;font-family:sans-serif;background:#fff;margin:40px;border-radius:12px;border:2px solid red'><h2 style='color:red'>Error</h2><p>"+e.message+"</p><pre style='font-size:11px;margin-top:8px'>"+e.stack+"</pre></div>";
} }));
      body.appendChild(row);
    } else if(step===3){
      const m2=S.mitras.find(x=>x.id===form.mitraId);
      const rev=div(""); rev.style.cssText="background:#f5faff;border:1.5px solid #b8d9f0;border-radius:12px;padding:16px;margin-bottom:16px";
      const rh=div("row"); rh.style.marginBottom="12px";
      append(rh,av(m2?.name||"?",44),(()=>{const d=div(""); d.innerHTML=`<div style="font-weight:800;font-size:15px">${m2?.name||"?"}</div><div style="font-size:12px;color:#5a7a99">${fmt(form.date)}</div>`; return d;})(),div("sp"),(()=>{const d=div(""); d.style.textAlign="right"; d.innerHTML=`<div style="font-size:11px;color:#5a7a99;font-weight:700">Overall Score</div><div style="font-size:28px;font-weight:800;color:#2196f3">${avg(form.scores)}<span style="font-size:14px;color:#5a7a99">/ 5</span></div>`; return d;})());
      rev.appendChild(rh);
      cs.forEach(cat=>{
        rev.appendChild(mk("div","",`<div style="font-size:12px;font-weight:800;color:#1565c0;margin-bottom:6px;margin-top:10px">${cat.name}</div>`));
        const grid=div(""); grid.style.cssText="display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:6px";
        cat.subs.forEach(sub=>{ const s=form.scores[sub.id]||0; const item=div(""); item.style.cssText=`display:flex;justify-content:space-between;align-items:center;background:#fff;border:1.5px solid #b8d9f0;border-radius:8px;padding:6px 10px`; item.innerHTML=`<span style="font-size:12px;font-weight:600">${sub.name}</span><span style="font-weight:800;font-size:14px;color:${s>=4?"#00c853":s>=3?"#ff9800":"#f44336"}">${s}</span>`; grid.appendChild(item); });
        rev.appendChild(grid);
      });
      body.appendChild(rev);
      const nf=div("frow"); nf.appendChild(mk("label","fl2","Notes (optional)"));
      const ta=el("textarea",{class:"fta",placeholder:"Add observations…"}); ta.value=form.notes; ta.oninput=()=>form.notes=ta.value; nf.appendChild(ta); body.appendChild(nf);
      const row=div("row"); row.style.marginTop="16px";
      row.appendChild(btn("btn-g","← Back",()=>{ step=2; rewindow.onerror=function(msg,src,line){
  document.getElementById("root").innerHTML="<div style='padding:40px;font-family:sans-serif;background:#fff;margin:40px;border-radius:12px;border:2px solid red'><h2 style='color:red'>JS Error</h2><p>"+msg+"</p><p>Line: "+line+"</p></div>";
};
try{ draw(); }catch(e){
  document.getElementById("root").innerHTML="<div style='padding:40px;font-family:sans-serif;background:#fff;margin:40px;border-radius:12px;border:2px solid red'><h2 style='color:red'>Error</h2><p>"+e.message+"</p><pre style='font-size:11px;margin-top:8px'>"+e.stack+"</pre></div>";
} })); row.appendChild(div("sp"));
      const saveEv=async(status)=>{
        try{
          let eid=form.id;
          if(eid){ await DB.editEval(eid,{...form,status,date:form.date}); await DB.delScores(eid); }
          else{ const r=await DB.addEval({...form,officerId:S.user.id,status}); eid=r[0].id; }
          await DB.addScores(eid,form.scores);
          toast(status==="Submitted"?"Submitted 📤":"Draft saved 💾"); await load(); set({modal:null});
        }catch(e){toast(e.message,"err");}
      };
      row.appendChild(btn("btn-g","💾 Save Draft",()=>saveEv("Draft")));
      row.appendChild(btn("btn-p","📤 Submit for Approval",()=>saveEv("Submitted")));
      body.appendChild(row);
    }
  }
  rewindow.onerror=function(msg,src,line){
  document.getElementById("root").innerHTML="<div style='padding:40px;font-family:sans-serif;background:#fff;margin:40px;border-radius:12px;border:2px solid red'><h2 style='color:red'>JS Error</h2><p>"+msg+"</p><p>Line: "+line+"</p></div>";
};
try{ draw(); }catch(e){
  document.getElementById("root").innerHTML="<div style='padding:40px;font-family:sans-serif;background:#fff;margin:40px;border-radius:12px;border:2px solid red'><h2 style='color:red'>Error</h2><p>"+e.message+"</p><pre style='font-size:11px;margin-top:8px'>"+e.stack+"</pre></div>";
} return mo;
}

