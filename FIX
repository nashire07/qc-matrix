<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>QC Matrix ⭐</title>
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&family=Poppins:wght@600;700;800&display=swap" rel="stylesheet"/>
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html,body{height:100%;font-family:'Nunito',sans-serif;background:#e8f4fd;color:#1a2b42;font-size:14px}
    #root{min-height:100vh}
    .lg-bg{min-height:100vh;background:linear-gradient(135deg,#1565c0,#0d47a1 50%,#1a237e);display:flex;align-items:center;justify-content:center;padding:20px}
    .lg-c{background:#fff;border-radius:20px;padding:40px;width:100%;max-width:420px;box-shadow:0 20px 60px rgba(13,71,161,.3)}
    .lg-l{font-family:'Poppins',sans-serif;font-size:26px;font-weight:800;color:#1565c0;margin-bottom:6px}
    .lg-l span{color:#ffc107}
    .lg-s{font-size:13px;color:#5a7a99;margin-bottom:28px;font-weight:500}
    .fl{display:block;font-size:12px;font-weight:700;letter-spacing:.05em;text-transform:uppercase;color:#5a7a99;margin-bottom:6px}
    .fi{width:100%;background:#f5faff;border:1.5px solid #b8d9f0;border-radius:10px;padding:10px 14px;color:#1a2b42;font-size:14px;font-family:'Nunito',sans-serif;outline:none;margin-bottom:14px;transition:all .15s}
    .fi:focus{border-color:#2196f3;background:#fff;box-shadow:0 0 0 3px rgba(33,150,243,.1)}
    .fi-s{width:100%;background:#f5faff;border:1.5px solid #b8d9f0;border-radius:10px;padding:10px 14px;color:#1a2b42;font-size:14px;font-family:'Nunito',sans-serif;outline:none;transition:all .15s}
    .fi-s:focus{border-color:#2196f3}
    .fta{width:100%;background:#f5faff;border:1.5px solid #b8d9f0;border-radius:10px;padding:10px 14px;color:#1a2b42;font-size:14px;font-family:'Nunito',sans-serif;outline:none;min-height:80px;resize:vertical}
    .btn-login{width:100%;background:linear-gradient(135deg,#1e88e5,#1565c0);color:#fff;border:none;border-radius:10px;padding:12px;font-size:15px;font-weight:700;cursor:pointer;font-family:'Nunito',sans-serif;margin-top:4px}
    .btn-login:hover{opacity:.92}
    .err-box{background:#ffebee;border:1.5px solid #ef9a9a;color:#c62828;padding:10px 14px;border-radius:10px;font-size:13px;font-weight:600;margin-bottom:14px}
    .hint{margin-top:16px;background:#e3f2fd;border-radius:10px;padding:12px 14px;font-size:12px;color:#1565c0;font-weight:600}
    .hint strong{display:block;margin-bottom:6px;font-size:13px}
    .hint-row{cursor:pointer;padding:3px 0;text-decoration:underline;opacity:.8}
    .hint-row:hover{opacity:1}
    .app{display:flex;min-height:100vh}
    .sidebar{width:230px;min-height:100vh;background:linear-gradient(180deg,#1565c0,#0d47a1);display:flex;flex-direction:column;position:sticky;top:0;height:100vh;overflow-y:auto;flex-shrink:0;box-shadow:4px 0 20px rgba(21,101,192,.2);z-index:100}
    .sl{padding:24px 20px 20px;border-bottom:1px solid rgba(255,255,255,.12)}
    .sl-t{font-family:'Poppins',sans-serif;font-size:17px;font-weight:800;color:#fff}
    .sl-t span{color:#ffc107}
    .sl-s{font-size:11px;color:rgba(255,255,255,.5);font-weight:600;margin-top:2px}
    .ns{padding:16px 14px 4px;font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.4);font-weight:700}
    .ni{display:flex;align-items:center;gap:10px;padding:11px 14px;margin:2px 10px;border-radius:10px;cursor:pointer;font-size:14px;color:rgba(255,255,255,.75);font-weight:600;border:none;background:none;width:calc(100% - 20px);text-align:left;transition:all .18s}
    .ni:hover{background:rgba(255,255,255,.12);color:#fff}
    .ni.active{background:#fff;color:#1565c0;font-weight:700}
    .up-btn{display:flex;align-items:center;gap:8px;padding:10px 14px;background:rgba(255,255,255,.12);border-radius:10px;margin:10px;cursor:pointer;border:none;width:calc(100% - 20px);text-align:left}
    .up-btn:hover{background:rgba(255,255,255,.2)}
    .un{font-size:13px;font-weight:700;color:#fff}
    .ur{font-size:10px;color:rgba(255,255,255,.55);font-weight:600;text-transform:uppercase}
    .av{width:36px;height:36px;border-radius:10px;background:linear-gradient(135deg,#42a5f5,#1565c0);display:inline-flex;align-items:center;justify-content:center;font-family:'Poppins',sans-serif;font-size:15px;font-weight:800;color:#fff;flex-shrink:0}
    .topbar{display:none;align-items:center;gap:12px;padding:14px 16px;background:#fff;border-bottom:1.5px solid #b8d9f0;position:sticky;top:0;z-index:99;box-shadow:0 2px 12px rgba(21,101,192,.1)}
    .hbg{background:none;border:none;font-size:22px;cursor:pointer;color:#1565c0;padding:4px 8px}
    .mob-ov{display:none;position:fixed;inset:0;background:rgba(13,71,161,.45);z-index:98}
    .mob-ov.open{display:block}
    .mob-sb{position:fixed;left:0;top:0;bottom:0;width:240px;background:linear-gradient(180deg,#1565c0,#0d47a1);z-index:99;overflow-y:auto;transform:translateX(-100%);transition:transform .25s;display:flex;flex-direction:column}
    .mob-sb.open{transform:translateX(0)}
    .main-area{flex:1;background:#e8f4fd;padding:28px;overflow-y:auto}
    .page-title{font-family:'Poppins',sans-serif;font-size:22px;font-weight:800;color:#1a2b42;margin-bottom:4px}
    .page-sub{font-size:13px;color:#5a7a99;font-weight:600;margin-bottom:24px}
    .stats{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:20px}
    .stat{background:#fff;border:1.5px solid #b8d9f0;border-radius:14px;padding:20px;box-shadow:0 2px 12px rgba(21,101,192,.1)}
    .stat-l{font-size:11px;font-weight:700;color:#5a7a99;text-transform:uppercase;letter-spacing:.06em}
    .stat-v{font-family:'Poppins',sans-serif;font-size:32px;font-weight:800;margin-top:4px}
    .card{background:#fff;border:1.5px solid #b8d9f0;border-radius:14px;padding:20px;box-shadow:0 2px 12px rgba(21,101,192,.1);margin-bottom:16px}
    .card-t{font-family:'Poppins',sans-serif;font-size:12px;font-weight:700;color:#5a7a99;margin-bottom:14px;text-transform:uppercase;letter-spacing:.05em}
    .tw{overflow-x:auto}
    table{width:100%;border-collapse:collapse;font-size:13.5px}
    th{text-align:left;padding:10px 14px;font-size:11px;letter-spacing:.06em;text-transform:uppercase;color:#5a7a99;font-weight:700;border-bottom:2px solid #b8d9f0;background:#f0f8ff}
    td{padding:12px 14px;border-bottom:1px solid #b8d9f0;vertical-align:middle}
    tr:last-child td{border-bottom:none}
    tr:hover td{background:#f5fbff}
    .badge{display:inline-flex;align-items:center;padding:4px 11px;border-radius:99px;font-size:12px;font-weight:700}
    .badge.on-time,.badge.Approved{background:#e8f5e9;color:#2e7d32}
    .badge.due-soon{background:#fff8e1;color:#e65100}
    .badge.overdue{background:#ffebee;color:#c62828}
    .badge.Submitted{background:#e3f2fd;color:#1565c0}
    .badge.Draft{background:#f5f5f5;color:#757575}
    .pb{height:7px;background:#d6ecfb;border-radius:99px;overflow:hidden;width:60px;display:inline-block}
    .pf{height:100%;border-radius:99px;background:linear-gradient(90deg,#42a5f5,#1565c0)}
    .btn-p{padding:9px 18px;border-radius:10px;font-size:14px;font-weight:700;cursor:pointer;border:none;background:linear-gradient(135deg,#1e88e5,#1565c0);color:#fff;font-family:'Nunito',sans-serif}
    .btn-p:hover{opacity:.92}
    .btn-g{padding:9px 18px;border-radius:10px;font-size:14px;font-weight:700;cursor:pointer;border:1.5px solid #b8d9f0;background:#fff;color:#1565c0;font-family:'Nunito',sans-serif}
    .btn-g:hover{background:#e3f2fd;border-color:#2196f3}
    .btn-ok{padding:4px 12px;border-radius:7px;font-size:12px;font-weight:700;cursor:pointer;border:none;background:linear-gradient(135deg,#00c853,#00897b);color:#fff;font-family:'Nunito',sans-serif}
    .btn-sm{padding:4px 12px;border-radius:7px;font-size:12px;font-weight:700;cursor:pointer;border:1.5px solid #b8d9f0;background:#fff;color:#1565c0;font-family:'Nunito',sans-serif;margin:2px}
    .btn-sm:hover{background:#e3f2fd;border-color:#2196f3}
    .btn-del{padding:4px 12px;border-radius:7px;font-size:12px;font-weight:700;cursor:pointer;border:1.5px solid #ffcdd2;background:#ffebee;color:#f44336;font-family:'Nunito',sans-serif;margin:2px}
    .btn-del:hover{background:#ffcdd2}
    .row{display:flex;align-items:center;gap:12px}
    .sp{flex:1}
    .info-bar{background:#e3f2fd;border:1.5px solid #90caf9;color:#1565c0;padding:12px 16px;border-radius:11px;font-size:13px;font-weight:600;margin-bottom:12px;display:flex;gap:8px;align-items:center}
    .tabs{display:flex;gap:4px;border-bottom:2px solid #b8d9f0;margin-bottom:20px}
    .tab{padding:9px 18px;font-size:14px;font-weight:700;cursor:pointer;border:none;background:none;color:#5a7a99;border-bottom:3px solid transparent;margin-bottom:-2px;border-radius:8px 8px 0 0}
    .tab.active{color:#2196f3;border-bottom-color:#2196f3;background:#e3f2fd}
    .tab-cnt{font-size:10px;background:#d6ecfb;border-radius:99px;padding:1px 7px;margin-left:5px}
    .toast{position:fixed;top:20px;right:20px;z-index:9999;padding:12px 20px;border-radius:12px;font-weight:700;font-size:14px;box-shadow:0 4px 20px rgba(0,0,0,.15);display:none;font-family:'Nunito',sans-serif}
    .toast.ok{background:#e8f5e9;color:#2e7d32;border:1.5px solid #a5d6a7;display:block}
    .toast.err{background:#ffebee;color:#c62828;border:1.5px solid #ef9a9a;display:block}
    .empty{text-align:center;padding:48px;color:#5a7a99}
    .empty-i{font-size:40px;margin-bottom:12px}
    .modal-bg{position:fixed;inset:0;background:rgba(13,71,161,.4);display:flex;align-items:center;justify-content:center;z-index:1000;padding:16px}
    .modal{background:#fff;border:1.5px solid #b8d9f0;border-radius:18px;width:100%;max-width:560px;max-height:90vh;overflow-y:auto;padding:28px;position:relative;box-shadow:0 20px 60px rgba(21,101,192,.2)}
    .modal.wide{max-width:800px}
    .modal-t{font-family:'Poppins',sans-serif;font-size:19px;font-weight:800;margin-bottom:20px;color:#1a2b42}
    .modal-x{position:absolute;top:16px;right:16px;background:#f0f8ff;border:1.5px solid #b8d9f0;border-radius:8px;width:32px;height:32px;cursor:pointer;font-size:16px;display:flex;align-items:center;justify-content:center;font-weight:700;color:#5a7a99;z-index:1}
    .modal-x:hover{background:#ffebee;color:#f44336}
    .frow{margin-bottom:14px}
    .fl2{display:block;font-size:12px;font-weight:700;letter-spacing:.05em;text-transform:uppercase;color:#5a7a99;margin-bottom:6px}
    .grid2{display:grid;grid-template-columns:1fr 1fr;gap:12px}
    .srow{display:flex;align-items:center;justify-content:space-between;padding:11px 0;border-bottom:1px solid #b8d9f0}
    .srow:last-child{border-bottom:none}
    .slbl{font-size:13.5px;color:#1a2b42;font-weight:600}
    .sbts{display:flex;gap:6px}
    .sbt{width:36px;height:36px;border-radius:9px;border:1.5px solid #b8d9f0;background:#f5faff;color:#5a7a99;font-size:14px;font-weight:700;cursor:pointer;font-family:'Nunito',sans-serif}
    .sbt:hover{border-color:#2196f3;color:#2196f3;background:#e3f2fd}
    .sbt.s1.act{background:#f44336;color:#fff;border-color:#f44336}
    .sbt.s2.act{background:#ff9800;color:#fff;border-color:#ff9800}
    .sbt.s3.act{background:#ffc107;color:#fff;border-color:#ffc107}
    .sbt.s4.act{background:#8bc34a;color:#fff;border-color:#8bc34a}
    .sbt.s5.act{background:#00c853;color:#fff;border-color:#00c853}
    .wiz-steps{display:flex;align-items:center;margin-bottom:24px}
    .wiz-step{display:flex;align-items:center;gap:8px;flex:1}
    .wiz-c{width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:800;flex-shrink:0}
    .wiz-c.done{background:#00c853;color:#fff}
    .wiz-c.active{background:#2196f3;color:#fff}
    .wiz-c.pend{background:#e0e0e0;color:#9e9e9e}
    .wiz-l{font-size:12px;font-weight:700;color:#5a7a99}
    .wiz-l.active{color:#2196f3}
    .wiz-line{flex:1;height:2px;background:#b8d9f0;margin:0 8px}
    .wiz-line.done{background:#00c853}
    .cat-tag{display:inline-flex;align-items:center;gap:6px;padding:8px 12px;background:#e8f4fd;border-radius:9px;font-size:13px;font-weight:600;border:1.5px solid #b8d9f0;margin:4px}
    .loading-wrap{display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:100vh;gap:16px;background:#e8f4fd}
    .spin{display:inline-block;width:36px;height:36px;border:4px solid rgba(21,101,192,.15);border-top-color:#2196f3;border-radius:50%;animation:sp .7s linear infinite}
    @keyframes sp{to{transform:rotate(360deg)}}
    @media(max-width:768px){
      .sidebar{display:none}
      .topbar{display:flex}
      .stats{grid-template-columns:repeat(2,1fr)}
      .main-area{padding:16px}
      .grid2{grid-template-columns:1fr}
    }
  </style>
</head>
<body>
<div id="root"></div>
<div id="toast" class="toast"></div>

<script>
// ══════════════════════
// SUPABASE
// ══════════════════════
const SURL = "https://njblmbumywwcjwtybmmz.supabase.co";
const SKEY = "sb_publishable_lgAEKgxrbYhZVqvLEJTlbg_v2DDQCfU";

async function sbFetch(path, opts={}) {
  const r = await fetch(`${SURL}/rest/v1/${path}`, {
    headers: { apikey:SKEY, Authorization:`Bearer ${SKEY}`, "Content-Type":"application/json", Prefer: opts.prefer||"return=representation", ...opts.headers },
    ...opts
  });
  if(!r.ok){ const e=await r.json().catch(()=>{}); throw new Error((e&&e.message)||"Request failed: "+r.status); }
  const t=await r.text(); return t?JSON.parse(t):[];
}

const DB = {
  login:      (e,p) => sbFetch(`users?email=eq.${encodeURIComponent(e)}&select=*`).then(r=>{ if(!r.length) throw new Error("Email tidak ditemukan"); if(r[0].password!==p) throw new Error("Password salah"); return r[0]; }),
  mitras:     ()    => sbFetch("mitras?select=*&order=name"),
  addMitra:   (d)   => sbFetch("mitras",{method:"POST",body:JSON.stringify({name:d.name,employee_id:d.eid,join_date:d.jd||null})}),
  editMitra:  (id,d)=> sbFetch(`mitras?id=eq.${id}`,{method:"PATCH",body:JSON.stringify({name:d.name,employee_id:d.eid,join_date:d.jd||null})}),
  delMitra:   (id)  => sbFetch(`mitras?id=eq.${id}`,{method:"DELETE",prefer:"return=minimal"}),
  cats:       ()    => sbFetch("categories?select=*&order=sort_order,name"),
  subs:       ()    => sbFetch("sub_competencies?select=*&order=sort_order,name"),
  evals:      ()    => sbFetch("evaluations?select=*&order=eval_date.desc"),
  scores:     ()    => sbFetch("evaluation_scores?select=*"),
  addEval:    (d)   => sbFetch("evaluations",{method:"POST",body:JSON.stringify({mitra_id:d.mitraId,officer_id:d.officerId,status:d.status,eval_date:d.date,notes:d.notes||""})}),
  editEval:   (id,d)=> sbFetch(`evaluations?id=eq.${id}`,{method:"PATCH",body:JSON.stringify({status:d.status,eval_date:d.date,notes:d.notes||""})}),
  setStatus:  (id,s)=> sbFetch(`evaluations?id=eq.${id}`,{method:"PATCH",body:JSON.stringify({status:s})}),
  addScores:  (eid,sc)=> sbFetch("evaluation_scores",{method:"POST",body:JSON.stringify(Object.entries(sc).map(([sid,score])=>({evaluation_id:eid,sub_competency_id:sid,score})))}),
  delScores:  (eid) => sbFetch(`evaluation_scores?evaluation_id=eq.${eid}`,{method:"DELETE",prefer:"return=minimal"}),
};

// ══════════════════════
// STATE
// ══════════════════════
let S = { user:null, page:"dashboard", mob:false, modal:null, loading:false, evalTab:"all",
          mitras:[], cats:[], subs:[], evals:[], scores:[] };

function set(patch){ Object.assign(S, typeof patch==="function"?patch(S):patch); window.onerror=function(msg,src,line){
  document.getElementById("root").innerHTML="<div style='padding:40px;font-family:sans-serif;background:#fff;margin:40px;border-radius:12px;border:2px solid red'><h2 style='color:red'>JS Error</h2><p>"+msg+"</p><p>Line: "+line+"</p></div>";
};
try{ draw(); }catch(e){
  document.getElementById("root").innerHTML="<div style='padding:40px;font-family:sans-serif;background:#fff;margin:40px;border-radius:12px;border:2px solid red'><h2 style='color:red'>Error</h2><p>"+e.message+"</p><pre style='font-size:11px;margin-top:8px'>"+e.stack+"</pre></div>";
} }

// ══════════════════════
// HELPERS
// ══════════════════════
const today = new Date();
const avg = sc => { const v=Object.values(sc); return v.length?(v.reduce((a,b)=>a+b,0)/v.length).toFixed(1):0; };
const status = d => { if(!d) return "overdue"; const days=(today-new Date(d))/86400000; return days<=50?"on-time":days<=60?"due-soon":"overdue"; };
const nextDue = d => { if(!d)return"—"; const x=new Date(d); x.setDate(x.getDate()+60); return x.toLocaleDateString("id-ID",{day:"2-digit",month:"short",year:"numeric"}); };
const fmt = d => d?new Date(d).toLocaleDateString("id-ID",{day:"2-digit",month:"short",year:"numeric"}):"—";
const ini = n => n?n[0].toUpperCase():"?";

let _toast;
function toast(msg, type="ok"){ const t=document.getElementById("toast"); t.textContent=msg; t.className="toast "+type; clearTimeout(_toast); _toast=setTimeout(()=>t.className="toast",3000); }

async function load(){
  set({loading:true});
  try{
    const [mitras,cats,subs,evals,scores] = await Promise.all([DB.mitras(),DB.cats(),DB.subs(),DB.evals(),DB.scores()]);
    set({mitras,cats,subs,evals,scores,loading:false});
  }catch(e){ toast("Gagal load: "+e.message,"err"); set({loading:false}); }
}

function scoreMap(){ const m={}; S.scores.forEach(s=>{ if(!m[s.evaluation_id])m[s.evaluation_id]={}; m[s.evaluation_id][s.sub_competency_id]=s.score; }); return m; }
function richEvals(){ const sm=scoreMap(); return S.evals.map(e=>({...e,scores:sm[e.id]||{}})); }
function catsWithSubs(){ return S.cats.map(c=>({...c,subs:S.subs.filter(s=>s.category_id===c.id)})); }
function mStats(){
  const re=richEvals();
  return S.mitras.map(m=>{
    const ok=re.filter(e=>e.mitra_id===m.id&&e.status==="Approved").sort((a,b)=>new Date(b.eval_date)-new Date(a.eval_date));
    const last=ok[0]||null;
    return {...m,last,evalStatus:status(last?.eval_date),nextDue:nextDue(last?.eval_date),avgScore:last?avg(last.scores):null};
  });
}

// ══════════════════════
// DOM HELPERS
// ══════════════════════
function el(tag,attrs,html){
  const e=document.createElement(tag);
  if(attrs) for(const [k,v] of Object.entries(attrs)){
    if(k==="class")e.className=v;
    else if(k.startsWith("on"))e[k]=v;
    else e.setAttribute(k,v);
  }
  if(html!==undefined) e.innerHTML=html;
  return e;
}
function div(cls,html){ return el("div",{class:cls},html); }
function mk(tag,cls,html){ return el(tag,{class:cls},html); }
function btn(cls,html,fn){ const b=el("button",{class:cls},html); b.onclick=fn; return b; }
function append(parent,...children){ children.flat().forEach(c=>c&&parent.appendChild(c)); return parent; }
function av(n,sz=36){ const d=el("div",{class:"av",style:`width:${sz}px;height:${sz}px;font-size:${Math.round(sz*0.4)}px`}); d.textContent=ini(n); return d; }

// ══════════════════════
// DRAW
// ══════════════════════
function draw(){
  const root=document.getElementById("root");
  root.innerHTML="";
  if(!S.user){ root.appendChild(drawLogin()); return; }
  if(S.loading){ root.appendChild(drawLoading()); return; }
  root.appendChild(drawApp());
  if(S.modal) document.body.appendChild(drawModal());
}

// ══════════════════════
// LOGIN
// ══════════════════════
function drawLogin(){
  const wrap=div("lg-bg");
  const card=div("lg-c");
  const logo=div("lg-l"); logo.innerHTML='QC <span>Matrix</span> ⭐'; card.appendChild(logo);
  card.appendChild(mk("p","lg-s","Central Kitchen · Skill Tracker"));

  const errBox=div("err-box"); errBox.style.display="none"; card.appendChild(errBox);

  const emailI=el("input",{class:"fi",type:"email",placeholder:"your@email.com"});
  const pwI=el("input",{class:"fi",type:"password",placeholder:"••••••••"});

  const ef=div("frow"); append(ef,mk("label","fl","Email"),emailI); card.appendChild(ef);
  const pf=div("frow"); append(pf,mk("label","fl","Password"),pwI); card.appendChild(pf);

  const loginBtn=btn("btn-login","Sign In →",async()=>{
